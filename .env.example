# Skopiuj ten plik poza repozytorium (domyslnie ~/.secrets/gmail-plugin.env)
# lub wskaz jego sciezke zmienna srodowiskowa GMAIL_PLUGIN_ENV.
# NIGDY nie commituj prawdziwego pliku .env z poswiadczeniami.

# Adres konta Gmail
GMAIL_USER=twoj.adres@gmail.com

# 16-znakowy App Password (NIE zwykle haslo do konta).
# Wymaga wlaczonego 2FA oraz IMAP w ustawieniach Gmaila.
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
